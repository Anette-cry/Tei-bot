# ── Anti-spam ────────────────────────────────────────────────────────────────

def contains_spam(text: str) -> bool:
    lower = text.lower()
    if URL_PATTERN.search(text):
        return True
    if any(kw in lower for kw in EXPLICIT_KEYWORDS):
        return True
    return False


async def admin_ping(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not update.message or not update.message.text:
        return
    if "@admin" not in update.message.text.lower():
        return

    menciones = []
    for admin_id in ADMINS:
        try:
            member = await context.bot.get_chat_member(update.effective_chat.id, admin_id)
            menciones.append(member.user.mention_html())
        except Exception:
            pass

    if not menciones:
        return

    admins_texto = " ".join(menciones)
    respuesta = (
        f"{admins_texto}\n\n"
        "📜 Vuestro mensaje ha sido emitido; cuando nuestras administradoras se hallen "
        "disponibles, responderán vuestra consulta con sumo gusto 🙂"
    )
    await update.message.reply_text(respuesta, parse_mode="HTML")


async def anti_spam(update: Update, context: ContextTypes.DEFAULT_TYPE):
    message = update.message
    if not message or not message.text:
        return

    entities = message.entities or []
    has_link = any(e.type in ("url", "text_link", "mention") for e in entities)

    if has_link or contains_spam(message.text):
        try:
            await message.delete()
            warning = await message.chat.send_message(
                "⚠️ Mensaje eliminado: no se permiten enlaces, canales externos ni contenido explícito."
            )
            asyncio.create_task(
                delete_after(context.bot, warning.chat_id, warning.message_id, delay=30)
            )
        except Exception:
            pass



    ("👑", "Soberano del Reino Carmesí", "Triunfador/a"),
    ("🥈", "Caballero de la Rosa de Plata", None),
    ("🥉", "Guardián del Umbral Escarlata", None),
]


# ── Helpers ───────────────────────────────────────────────────────────────────

async def _is_admin(context: ContextTypes.DEFAULT_TYPE, chat_id: int, user_id: int) -> bool:
    member = await context.bot.get_chat_member(chat_id, user_id)
    return member.status in ("administrator", "creator")


async def _send_trivia(bot, chat_id: int):
    if chat_id in active_questions:
        return
    pregunta = random.choice(PREGUNTAS)
    active_questions[chat_id] = {"question": pregunta["q"], "answer": pregunta["a"]}
    await bot.send_message(
        chat_id,
        "🌹 PREGUNTA DEL REINO 🌹\n\n"
        f"{pregunta['q']}\n\n"
        "⏳ El primero en responder correctamente gana un punto de gloria."
    )


# ── Auto-trivia job (every 1 hour) ────────────────────────────────────────────

async def auto_trivia(context: ContextTypes.DEFAULT_TYPE):
    for chat_id in list(known_chats):
        if chat_id in paused_chats:
            continue
        try:
            await _send_trivia(context.bot, chat_id)
        except Exception:
            pass


